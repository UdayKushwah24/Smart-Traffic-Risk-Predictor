# Backend Environment Variables
# Copy this file to .env and fill in actual values

# MongoDB Atlas connection URI
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.<shard>.mongodb.net/?appName=<appname>

# JWT Secret (min 32 chars; generate with: python -c "import secrets; print(secrets.token_urlsafe(48))")
JWT_SECRET_KEY=your_generated_secret_key_here

# Logging level (DEBUG|INFO|WARNING|ERROR|CRITICAL)
LOG_LEVEL=INFO

# Optional: Model paths (leave empty to use defaults)
FOG_MODEL_PATH=
AUDIO_ALERT_DROWSY_PATH=
AUDIO_ALERT_YAWN_PATH=
