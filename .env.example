# ========== CRITICAL FOR PRODUCTION ==========
# Webcam Streaming (Frontend → Backend)
# USE_EXTERNAL_FRAMES: Enable frame ingestion from frontend (default: true)
# ALLOW_LOCAL_CAMERA_FALLBACK: Disable to prevent cv2.VideoCapture(0) in production (default: false)
